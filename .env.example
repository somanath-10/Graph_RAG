# Required unless USE_MOCK_OPENAI=true
OPENAI_API_KEY=replace_me

# App metadata
APP_NAME=Patent Accuracy RAG
ENVIRONMENT=dev
API_KEY=
API_KEY_HEADER=X-API-Key
REQUIRE_API_KEY=false

# OpenAI models
OPENAI_SMALL_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
DEFAULT_TEXT_MAX_OUTPUT_TOKENS=1200
DEFAULT_JSON_MAX_OUTPUT_TOKENS=1800
PARSE_JSON_PREVIEW_CHARS=500
MOCK_ANSWER_TEXT=Mock answer. Set USE_MOCK_OPENAI=false and provide OPENAI_API_KEY for real answers.

# Qdrant
QDRANT_URL=http://localhost:6333
BACKEND_QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=patent_chunks
QDRANT_DISTANCE=COSINE
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://localhost:7687
BACKEND_NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687

# Backend server and CORS
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5177,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:5177

# Data locations
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
INDEX_DIR=data/indexes
DOCUMENT_REGISTRY_PATH=data/processed/documents.json
MAX_UPLOAD_BYTES=52428800
# Optional. Leave empty to use the first PDF in RAW_DIR for sample ingestion.
SAMPLE_PDF_FILENAME=

# External structured config files
SECTION_PATTERNS_PATH=config/section_patterns.json
NORMALIZER_REPLACEMENTS_PATH=config/normalizer_replacements.json
RETRIEVAL_TERMS_PATH=config/retrieval_terms.json
GRAPH_SCHEMA_PATH=config/graph_schema.json

# Chunking
CHUNK_MAX_WORDS=420
CHUNK_OVERLAP_WORDS=60
MIN_CHUNK_WORDS=5
MIN_CLAIM_WORDS=8
MIN_PARAGRAPH_WORDS=8
SENTENCE_SPLIT_MIN_CHARS=24
CLAIM_SECTION_NAME=Claims
BODY_SECTION_NAME=Body
CHUNK_ID_WIDTH=4

# Ingestion behavior
RESET_VECTOR_STORE_ON_INGEST=true
RESET_GRAPH_STORE_ON_INGEST=true
MAX_GRAPH_CHUNKS=25
GRAPH_PRIORITY_SECTIONS=Claims,Examples,Abstract,Summary,Detailed Description

# Retrieval and query behavior
DEFAULT_QUERY_TOP_K=12
MAX_QUERY_TOP_K=50
VECTOR_SOURCE_UNIT_TYPES=claim,example,paragraph
BM25_TOP_K_MULTIPLIER=3
EXACT_MATCH_LIMIT=12
SPROUT_BEAM_WIDTH=6
SPROUT_TREE_CANDIDATE_LIMIT=18
SPROUT_STORE_FILENAME=sprout_nodes.json
MAX_ANSWER_CONTEXTS=8
MIN_ANSWER_CONTEXTS=2
FALLBACK_TO_TOP_CONTEXTS_WHEN_EMPTY=true
GRAPH_FACT_LIMIT=40
RETRIEVAL_TERM_LIMIT=12
CONTEXT_CANDIDATE_CHARS=900
CONTEXT_RELEVANCE_THRESHOLD=0.25
CONTEXT_DEFAULT_KEEP_RELEVANCE=3
CONTEXT_DEFAULT_DROP_RELEVANCE=1
CONTEXT_EVAL_MAX_OUTPUT_TOKENS=1200

# Graph extraction and answer generation
GRAPH_CHUNK_TEXT_CHARS=8000
GRAPH_EXTRACTION_MAX_OUTPUT_TOKENS=1800
ANSWER_CHUNK_TEXT_CHARS=1800
ANSWER_FACT_LIMIT=30
ANSWER_MAX_OUTPUT_TOKENS=1400
NO_EVIDENCE_ANSWER=I do not have enough evidence in the retrieved patent context to answer that exactly.
INSUFFICIENT_CITATION_ANSWER=I do not have enough cited evidence in the retrieved patent context to answer that exactly.

# Graph API
DEFAULT_GRAPH_LIMIT=150
MAX_GRAPH_LIMIT=500

# Prompt files
CONTEXT_EVAL_SYSTEM_PROMPT_PATH=backend/app/prompts/context_eval_system.txt
CONTEXT_EVAL_USER_PROMPT_PATH=backend/app/prompts/context_eval_user.txt
GRAPH_EXTRACTION_SYSTEM_PROMPT_PATH=backend/app/prompts/graph_extraction_system.txt
GRAPH_EXTRACTION_USER_PROMPT_PATH=backend/app/prompts/graph_extraction_user.txt
ANSWER_SYSTEM_PROMPT_PATH=backend/app/prompts/answer_system.txt
ANSWER_USER_PROMPT_PATH=backend/app/prompts/answer_user.txt

# Set true only to test UI/backend without OpenAI calls. Real answers require false.
USE_MOCK_OPENAI=false

# Frontend build/runtime configuration
FRONTEND_PORT=5173
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_DEV_SERVER_PORT=5173
VITE_API_URL=http://localhost:8000/api
VITE_API_KEY=
VITE_API_KEY_HEADER=X-API-Key
VITE_APP_TITLE=Patent Accuracy RAG
VITE_APP_SUBTITLE=Evidence GraphRAG vs SproutRAG on the same patent evidence
VITE_DEFAULT_QUESTION=Which examples support claim 1?
VITE_EXAMPLE_QUESTIONS=What does claim 1 describe?||Which examples support claim 1?||Summarize the invention step by step.||What measurements, ranges, or conditions are disclosed?||What problem does the invention solve?
VITE_QUERY_TOP_K=12
VITE_GRAPH_LIMIT=120
VITE_SOURCE_PREVIEW_CHARS=260
VITE_FACT_PREVIEW_CHARS=220
VITE_MINIGRAPH_EDGE_LIMIT=12
